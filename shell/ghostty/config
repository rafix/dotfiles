# Ghostty terminal configuration
# Docs: https://ghostty.org/docs/config

# === Font ===
# Using Hack Nerd Font (installed via Homebrew)
# Alternative: "0xProto Nerd Font Mono" (also installed)
font-family = "MesloLGS Nerd Font Mono"
font-size = 16
font-thicken = true

# === Theme ===
# GruvboxDarkHard matches the FZF Gruvbox palette in exports.sh
theme = Gruvbox Dark Hard

# === Cursor ===
cursor-style = block
cursor-style-blink = true

# === Window ===
background-opacity = 0.90
window-padding-x = 8
window-padding-y = 8
window-save-state = always
macos-titlebar-style = tabs

# === macOS ===
macos-option-as-alt = true

# === Shell Integration ===
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# === Performance & Scrollback ===
scrollback-limit = 100000
mouse-scroll-multiplier = 2

# === Clipboard ===
copy-on-select = clipboard
clipboard-paste-protection = true
